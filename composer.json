{
    "name": "componenta/auth",
    "description": "Authentication contracts and helpers for Componenta applications",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "componenta/arrayable": "^1.0",
        "componenta/clock": "^1.0",
        "componenta/config": "^1.0",
        "componenta/cqrs": "^1.0",
        "componenta/di": "^1.0",
        "componenta/identity": "^1.0",
        "componenta/password": "^1.0",
        "cycle/database": "^2.15",
        "lcobucci/jwt": "^5.6",
        "psr/clock": "^1.0",
        "psr/container": "^2.0",
        "psr/http-message": "^2.0",
        "psr/http-server-middleware": "^1.0",
        "psr/log": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Componenta\\Auth\\": "src/"
        }
    },
    "minimum-stability": "stable",
    "extra": {
        "componenta": {
            "config-providers": [
                "Componenta\\Auth\\ConfigProvider"
            ]
        }
    }
}
